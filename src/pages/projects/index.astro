---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('projects', ({ data }) => !data.draft);
entries.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

function fmt(d?: Date) {
  return d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
}
---

<Base title="Projects" description="Things I'm building.">
  <h1>Projects</h1>
  <p>Outside-the-9-to-5 work and the leadership roles attached to it.</p>

  <ul class="post-list">
    {entries.map((p) => (
      <li>
        <a class="post-list-title" href={`/projects/${p.id}/`}>{p.data.title}</a>
        <span class="post-list-meta">{fmt(p.data.date)}</span>
        {p.data.description && <p class="post-list-desc">{p.data.description}</p>}
      </li>
    ))}
  </ul>
</Base>
