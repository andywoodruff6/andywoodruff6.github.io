---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('ideas', ({ data }) => !data.draft);
entries.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

function fmt(d?: Date) {
  return d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
}
---

<Base title="Ideas" description="Capturing my thoughts.">
  <h1>Ideas</h1>
  <p>
    Ideas shape who we are, and not enough of us are in touch with our true thoughts.
    Freedom of thought is only possible when you can express your thoughts and stand behind them.
  </p>

  <ul class="post-list">
    {entries.map((p) => (
      <li>
        <a class="post-list-title" href={`/ideas/${p.id}/`}>{p.data.title}</a>
        <span class="post-list-meta">{fmt(p.data.date)}</span>
        {p.data.description && <p class="post-list-desc">{p.data.description}</p>}
      </li>
    ))}
  </ul>
</Base>
