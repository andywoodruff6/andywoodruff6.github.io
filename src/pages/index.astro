---
import Base from '../layouts/Base.astro';
import Currently from '../components/Currently.astro';
import MissionMeter from '../components/MissionMeter.astro';
import { getCollection } from 'astro:content';

const sectionsToShow = ['ideas', 'predictions'] as const;

async function recentFor(section: typeof sectionsToShow[number], n: number) {
  const all = await getCollection(section, ({ data }) => !data.draft);
  return all
    .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
    .slice(0, n);
}

const [predictions, ideas] = await Promise.all([
  recentFor('predictions', 4),
  recentFor('ideas', 4),
]);

function fmt(d?: Date) {
  return d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
}
---

<Base title="Andy Woodruff" description="Andy Woodruff — Executive Director of OCME. Bringing self-sovereign identity to 100 million people by 2034.">
  <section class="home-intro">
    <h1>Andy Woodruff</h1>
    <p class="lede">
      I'm building self-sovereign identity for <a href="/2034/">100 million DIDs by 2034</a>
      as Executive Director of the <a href="https://ocmeco.org">Open Commercial Media Ecosystem</a>.
    </p>
    <p>
      The identity layer is the substrate. Everything else you do is built on top of it. When
      life went digital, technology providers quietly converted the most fundamental human asset
      — being a recognizable person in this world — into a permissioned service. 100 million is
      the tipping point. Below it, it's fringe. Above it, network effects will pull in the next
      billion without me.
    </p>
    <blockquote>
      You cannot be a free person in a world where someone else controls your identity.
    </blockquote>
  </section>

  <MissionMeter />

  <Currently />

  <section class="home-section">
    <h2 class="section-label"><span class="section-number">01</span> Predictions</h2>
    <ul class="post-list">
      {predictions.map((p) => (
        <li>
          <a class="post-list-title" href={`/predictions/${p.id}/`}>{p.data.title}</a>
          <span class="post-list-meta">{fmt(p.data.date)}</span>
          {p.data.description && <p class="post-list-desc">{p.data.description}</p>}
        </li>
      ))}
    </ul>
  </section>

  <section class="home-section">
    <h2 class="section-label"><span class="section-number">02</span> Ideas</h2>
    <ul class="post-list">
      {ideas.map((p) => (
        <li>
          <a class="post-list-title" href={`/ideas/${p.id}/`}>{p.data.title}</a>
          <span class="post-list-meta">{fmt(p.data.date)}</span>
          {p.data.description && <p class="post-list-desc">{p.data.description}</p>}
        </li>
      ))}
    </ul>
  </section>
</Base>
