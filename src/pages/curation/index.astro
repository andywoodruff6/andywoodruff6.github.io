---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('curation', ({ data }) => !data.draft);
entries.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

function typeFor(tags: string[]): string {
  const t = tags.map((x) => x.toLowerCase());
  if (t.includes('books') || t.includes('book')) return 'Book';
  if (t.includes('frameworks') || t.includes('framework')) return 'Framework';
  if (t.includes('articles') || t.includes('article')) return 'Article';
  if (t.includes('videos') || t.includes('video')) return 'Video';
  return 'Note';
}

function fmt(d?: Date) {
  return d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' }) : '';
}
---

<Base title="Curation" description="In an age of generative slop, curation is the most important skill.">
  <h1>Curation</h1>
  <p>
    Way too much noise. I want to help you find the signal — book notes, frameworks,
    and the few sources actually worth your time.
  </p>

  <ul class="entry-list">
    {entries.map((p) => (
      <li class="entry-card">
        <div class="entry-card-header">
          <span class="entry-role">{typeFor(p.data.tags)}</span>
          <a class="entry-title" href={`/curation/${p.id}/`}>{p.data.title}</a>
          {p.data.date && <span class="entry-date">{fmt(p.data.date)}</span>}
        </div>
        {p.data.description && <p class="entry-desc">{p.data.description}</p>}
      </li>
    ))}
  </ul>
</Base>
