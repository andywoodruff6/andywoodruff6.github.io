---
import '../styles/global.css';
import BadgerLogo from '../components/BadgerLogo.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const siteTitle = 'Andy Woodruff';
const newsletterName = 'The Shifting Current';
const author = siteTitle;
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          document.documentElement.dataset.theme = saved || 'light';
        } catch (_) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}

    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=ibm-plex-mono:400,500,600|ibm-plex-sans:400,400i,500,600,700&display=swap"
    />

    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="brand">
          <BadgerLogo size={36} class="brand-mark" />
          <span class="brand-text">
            Andy Woodruff
            <span class="brand-role">Executive Director · OCME</span>
          </span>
        </a>
        <ul>
          <li><a href="/2034/">2034</a></li>
          <li><a href="/projects/">Projects</a></li>
          <li><a href="/predictions/">Predictions</a></li>
          <li><a href="/ideas/">Ideas</a></li>
          <li><a href="/curation/">Curation</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/archives/">Archives</a></li>
        </ul>
        <ThemeToggle />
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <strong>{author}</strong> ·
        <a href="https://shiftingcurrent.substack.com">{newsletterName}</a> (newsletter) ·
        <a href="/rss.xml">RSS</a>
      </p>
      <p style="margin-top: 0.5rem; font-size: 0.78rem; opacity: 0.7;">
        © {new Date().getFullYear()} {author}
      </p>
    </footer>
  </body>
</html>
