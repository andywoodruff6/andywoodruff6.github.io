---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const siteTitle = 'Andy Woodruff';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}

    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="brand">Andy Woodruff</a>
        <ul>
          <li><a href="/projects/">Projects</a></li>
          <li><a href="/predictions/">Predictions</a></li>
          <li><a href="/ideas/">Ideas</a></li>
          <li><a href="/curation/">Curation</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/archives/">Archives</a></li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Andy Woodruff · <a href="https://shiftingcurrent.substack.com">Newsletter</a></p>
    </footer>
  </body>
</html>
