---
import Base from './Base.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import TLDR from '../components/TLDR.astro';
import AuthorBio from '../components/AuthorBio.astro';
import ShareButtons from '../components/ShareButtons.astro';

interface Aeo {
  tldr?: string;
  entity_type?: 'Article' | 'OpinionNewsArticle' | 'Prediction' | 'Project' | 'Review' | 'Theme';
  author?: string;
}

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  cover?: string;
  section?: string;
  kicker?: string;
  newsletter?: boolean;
  aeo?: Aeo;
}

const {
  title,
  description,
  date,
  tags = [],
  cover,
  section,
  kicker,
  newsletter = true,
  aeo,
} = Astro.props;

const formattedDate = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const author = aeo?.author ?? 'Andy Woodruff';
const entityType = aeo?.entity_type ?? 'Article';
const schemaType =
  entityType === 'Prediction' || entityType === 'Project' || entityType === 'Review' || entityType === 'Theme'
    ? 'Article'
    : entityType;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  headline: title,
  ...(description ? { description } : {}),
  ...(date ? { datePublished: date.toISOString() } : {}),
  author: {
    '@type': 'Person',
    name: author,
    url: new URL('/about/', Astro.site).toString(),
  },
  publisher: {
    '@type': 'Person',
    name: 'Andy Woodruff',
    url: new URL('/about/', Astro.site).toString(),
  },
  ...(cover ? { image: new URL(cover, Astro.site).toString() } : {}),
  mainEntityOfPage: canonicalURL,
  ...(aeo?.tldr ? { articleBody: aeo.tldr } : {}),
  ...(entityType === 'Prediction' ? { additionalType: 'Prediction' } : {}),
  ...(entityType === 'Theme' ? { articleSection: 'Annual Theme' } : {}),
};
---

<Base title={title} description={description} ogImage={cover}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  </Fragment>
  <article>
    {section && (
      <p class="post-meta">
        <a href={`/${section}/`} style="text-decoration: none; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem;">
          {section}
        </a>
      </p>
    )}
    {kicker && <p class="post-kicker">{kicker}</p>}
    <h1>{title}</h1>
    <p class="post-meta">
      {formattedDate && <span>{formattedDate}</span>}
      {tags.length > 0 && (
        <span style="margin-left: 0.5rem;">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </span>
      )}
    </p>
    {cover && <img src={cover} alt={title} />}
    {aeo?.tldr && <TLDR>{aeo.tldr}</TLDR>}
    <slot />
    <ShareButtons title={title} url={canonicalURL} />
    <AuthorBio />
    {newsletter && <NewsletterCTA variant="inline" />}
  </article>
</Base>
