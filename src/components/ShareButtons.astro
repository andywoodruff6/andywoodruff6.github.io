---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const t = encodeURIComponent(title);
const u = encodeURIComponent(url);
const bskyText = encodeURIComponent(`${title} ${url}`);

const xHref = `https://twitter.com/intent/tweet?text=${t}&url=${u}`;
const liHref = `https://www.linkedin.com/sharing/share-offsite/?url=${u}`;
const bsHref = `https://bsky.app/intent/compose?text=${bskyText}`;
const hnHref = `https://news.ycombinator.com/submitlink?u=${u}&t=${t}`;
---

<nav class="share" aria-label="Share this post">
  <a class="share-btn" href={xHref} target="_blank" rel="noopener noreferrer" aria-label="Share on X">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    <span>X</span>
  </a>
  <a class="share-btn" href={liHref} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14M7.12 20.45H3.56V9h3.56zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0"/></svg>
    <span>LinkedIn</span>
  </a>
  <a class="share-btn" href={bsHref} target="_blank" rel="noopener noreferrer" aria-label="Share on Bluesky">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364q.205-.03.415-.056-.207.033-.415.056c-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8 8 0 0 1-.415-.056q.21.026.415.056c2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8"/></svg>
    <span>Bluesky</span>
  </a>
  <a class="share-btn" href={hnHref} target="_blank" rel="noopener noreferrer" aria-label="Share on Hacker News">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M0 0v24h24V0zm6.951 4h2.27l2.78 5.5L14.781 4h2.27l-4.05 7.875V20h-2v-8.125z"/></svg>
    <span>Hacker News</span>
  </a>
  <button class="share-btn share-copy" type="button" data-url={url} aria-label="Copy link">
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <span class="share-copy-label">Copy link</span>
  </button>
</nav>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const u = btn.dataset.url;
      if (!u) return;
      try {
        await navigator.clipboard.writeText(u);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = u;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      const prev = btn.getAttribute('aria-label') ?? 'Copy link';
      const labelEl = btn.querySelector<HTMLElement>('.share-copy-label');
      const prevText = labelEl?.textContent ?? 'Copy link';
      btn.setAttribute('aria-label', 'Copied');
      if (labelEl) labelEl.textContent = 'Copied';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.setAttribute('aria-label', prev);
        if (labelEl) labelEl.textContent = prevText;
        btn.classList.remove('copied');
      }, 1500);
    });
  });
</script>

<style>
  .share {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    margin: var(--space-4) 0 var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 25%, transparent);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-sm);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .share-label {
    margin-right: 0.25rem;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-link);
    border-radius: 4px;
    background: transparent;
    color: var(--color-link);
    font: inherit;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 120ms ease, color 120ms ease;
  }
  .share-btn:hover,
  .share-btn:focus-visible {
    background: var(--color-link);
    color: var(--color-bg);
    outline: none;
  }
  .share-btn svg {
    width: 1rem;
    height: 1rem;
    display: block;
  }
  .share-btn.copied {
    background: var(--color-link);
    color: var(--color-bg);
  }
  @media (max-width: 640px) {
    .share-btn {
      padding: 0.45rem;
    }
    .share-btn > span {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>
