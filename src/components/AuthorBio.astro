---
const name = 'Andy Woodruff';
const role = 'Executive Director, Open Commercial Media Ecosystem (OCME)';
const bio =
  'I co-chair the Human Experience Working Group at the Trust Over IP Foundation. I write about self-sovereign identity, creator-governed ecosystems, and the transition to Human 3.0. Background: ME engineering, PMP, product, smart contracts.';
---

<aside class="author-bio" aria-label="About the author">
  <p class="author-bio-name">
    <a href="/about/">{name}</a>
  </p>
  <p class="author-bio-role">{role}</p>
  <p class="author-bio-text">{bio}</p>
</aside>

<style>
  .author-bio {
    margin: 3rem 0 1.5rem;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--accent, #b58900);
    background: var(--surface-muted, rgba(0, 0, 0, 0.03));
    border-radius: 0 4px 4px 0;
  }
  .author-bio-name {
    margin: 0 0 0.15rem;
    font-weight: 600;
    font-size: 1rem;
  }
  .author-bio-name a {
    text-decoration: none;
  }
  .author-bio-role {
    margin: 0 0 0.6rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.75;
  }
  .author-bio-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>
